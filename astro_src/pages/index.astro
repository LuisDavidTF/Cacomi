---
import Layout from '../layouts/Layout.astro';
import { RecipeFeed } from '@components/recipes/RecipeFeed';
import { LandingHero } from '@components/landing/LandingHero';
import { FeaturesSection } from '@components/landing/FeaturesSection';
import { FeatureAnnouncement } from '@components/landing/FeatureAnnouncement';
import { RecipeService } from '@/lib/services/recipes';

// Force dynamic SSR (do not prerender)
export const prerender = false;

// Cache feed for Cloudflare On-Demand Invalidation
Astro.response.headers.set('Cache-Control', 'public, s-maxage=0, stale-while-revalidate=31536000');
Astro.response.headers.set('Cache-Tag', 'recipes-feed');

const CURRENT_APP_VERSION = 'v1.1.0';

// Auth and Visit Tracking
const isAuthenticated = Astro.cookies.has('auth_token');
const hasEverLoggedIn = Astro.cookies.has('has_ever_logged_in') || isAuthenticated;
const visitCount = parseInt(Astro.cookies.get('home_visit_count')?.value || '0', 10);
const seenFeaturesVersion = Astro.cookies.get('seen_features_version')?.value;

// Business Logic
const isNewUser = !hasEverLoggedIn && visitCount < 3;
const hasNewFeatures = !isNewUser && seenFeaturesVersion !== CURRENT_APP_VERSION;

// Server-side Cookie Setting
if (!hasEverLoggedIn && !isAuthenticated) {
  // If showing landing to a non-authenticated user, increment valid visits
  Astro.cookies.set('home_visit_count', String(visitCount + 1), { path: '/', maxAge: 31536000 });
}

if (isAuthenticated && !Astro.cookies.has('has_ever_logged_in')) {
  // Mark permanently as a user who has logged in
  Astro.cookies.set('has_ever_logged_in', 'true', { path: '/', maxAge: 31536000 });
}

let initialData = { data: [], meta: { nextCursor: null } };
try {
  initialData = await RecipeService.getAll({}, { limit: 10 });
} catch (error) {
  console.error("Error fetching initial recipes:", error);
}
---

<Layout>
  {isNewUser && (
    <div id="new-user-landing">
      <LandingHero client:load />
      <FeaturesSection client:visible />
    </div>
  )}

  {hasNewFeatures && (
    <div id="new-feature-announcement">
      <FeatureAnnouncement version={CURRENT_APP_VERSION} client:load />
    </div>
  )}

  <div id="latest-recipes" class={isNewUser || hasNewFeatures ? "mt-4" : "mt-0"}>
    <RecipeFeed initialData={initialData} client:load />
  </div>
</Layout>
