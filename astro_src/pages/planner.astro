---
import Layout from '../layouts/Layout.astro';
import { translations } from '../context/SettingsContext';
import { WeeklyPlanner } from '../components/planner/WeeklyPlanner';

export const prerender = false;

// Planificador en desarrollo - Redirigir al inicio para el lanzamiento de mantenimiento
return Astro.redirect('/');

const lang = Astro.cookies.get('culina_language')?.value || 'es';
const t = translations[lang] || translations.es;
---

<Layout title={`${t.nav.planner} - ${t.nav.beta}`}>
  <WeeklyPlanner client:load />
</Layout>
