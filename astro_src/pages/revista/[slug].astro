---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const revistaEntries = await getCollection('revista');
  return revistaEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;

const { Content } = await render(entry);

// Fetch the full entries for all the articles referenced by their IDs
const articlesData = await Promise.all(
  entry.data.articles.map(async (id) => {
    const post = await getEntry('blog', id);
    if (!post) return null;
    const { Content: PostContent } = await render(post);
    return { post, PostContent };
  })
);

// Filter out any invalid references
const validArticles = articlesData.filter((a) => a !== null);
---

<Layout 
	title={`${entry.data.title} | Revista Cacomi`}
	description={entry.data.description}
>
	<div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 md:py-20">
		<a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 mb-8 transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
				<path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
			</svg>
			Volver al Blog
		</a>
        
        {entry.data.image && (
            <div class="relative mb-12 w-full overflow-hidden rounded-3xl shadow-xl border border-gray-100 dark:border-gray-800 bg-gray-100 dark:bg-gray-950 flex justify-center items-center group h-[300px] sm:h-[450px] md:h-[550px]">
                <div 
                    class="absolute inset-0 bg-cover bg-center blur-2xl opacity-25 scale-110 pointer-events-none" 
                    style={`background-image: url(${entry.data.image});`}
                ></div>
                <img 
                    src={entry.data.image} 
                    alt={entry.data.title} 
                    class="relative z-10 max-w-full max-h-full object-contain hover:scale-[1.02] transition-transform duration-700" 
                    loading="eager"
                />
            </div>
        )}

		<!-- Revista Header -->
		<header class="text-center mb-16 pb-12 border-b border-gray-200 dark:border-gray-800">
            <span class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-semibold tracking-wide uppercase mb-4">
                Edición #{entry.data.number}
            </span>
			<h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
				{entry.data.title}
			</h1>
			<div class="flex items-center justify-center gap-4 text-gray-500 dark:text-gray-400 mb-8">
				<time datetime={entry.data.date}>{entry.data.date}</time>
			</div>
            <div class="prose prose-lg dark:prose-invert max-w-none text-left">
                <Content />
            </div>
		</header>

		<!-- Revista Content (Long-form scrolling) -->
        <div class="space-y-32">
            {validArticles.map(({ post, PostContent }, index) => (
                <section id={post.id} class="scroll-mt-24">
                    <!-- Separador decorativo -->
                    {index > 0 && (
                        <div class="flex items-center justify-center gap-4 mb-20 opacity-30">
                            <div class="w-16 h-px bg-current"></div>
                            <span class="text-2xl">♦</span>
                            <div class="w-16 h-px bg-current"></div>
                        </div>
                    )}
                    
                    <div class="mb-10">
                        <span class="text-primary font-bold uppercase tracking-widest text-sm mb-2 block">
                            Sección {index + 1}
                        </span>
                        
                        {post.data.image && (
                            <a href={`/blog/${post.id}`} class="block mb-6 overflow-hidden rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 group">
                                <img 
                                    src={post.data.image} 
                                    alt={post.data.title} 
                                    class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-500" 
                                    loading="lazy"
                                />
                            </a>
                        )}

                        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
                            <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">
                                {post.data.title}
                            </a>
                        </h2>
                        <div class="text-gray-500 dark:text-gray-400 font-medium">
                            Por {post.data.author}
                        </div>
                    </div>
                    
                    <article class="prose prose-lg md:prose-xl dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-primary hover:prose-a:text-primary/80 prose-img:rounded-2xl prose-img:shadow-lg">
                        <PostContent />
                    </article>
                    
                    <div class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-800">
                        <a href={`/blog/${post.id}`} class="text-primary font-medium hover:underline flex items-center gap-1">
                            Leer comentarios o compartir este artículo
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </section>
            ))}
        </div>

        <!-- CTA Juego Diario -->
        <div class="mt-24 pt-16 border-t-2 border-dashed border-gray-200 dark:border-gray-800">
            <div class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-gray-800 dark:to-gray-900 rounded-3xl p-8 md:p-12 text-center shadow-inner border border-amber-100 dark:border-gray-700 relative overflow-hidden">
                <div class="absolute -top-10 -right-10 text-9xl opacity-10">🎮</div>
                <div class="relative z-10">
                    <span class="inline-block px-3 py-1 rounded-full bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-400 text-xs font-bold tracking-widest uppercase mb-4">
                        Reto Mental
                    </span>
                    <h3 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
                        ¿Ya descubriste la palabra de hoy?
                    </h3>
                    <p class="text-lg text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
                        Entrena tu mente al igual que cuidas tu cuerpo. Resuelve el desafío diario, no rompas tu racha y descubre el ingrediente secreto antes que nadie.
                    </p>
                    <a href="/juego" class="inline-block bg-primary hover:bg-primary/90 text-white font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                        Jugar Palabra del Día
                    </a>
                </div>
            </div>
        </div>
	</div>
</Layout>
