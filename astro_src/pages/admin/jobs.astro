---
import AdminLayout from '@layouts/AdminLayout.astro';
import { AdminGuard } from '@components/auth/AdminGuard';
import { JobsDataManager } from '@components/admin/jobs/JobsDataManager';
---

<AdminLayout title="Jobs Manager - Admin Panel">
    <AdminGuard client:only="react">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Background Process & Jobs</h1>
            <p class="text-slate-500 mt-2">Monitor, trigger, and stop long-running backend processes.</p>
        </div>

        <JobsDataManager client:only="react" />
    </AdminGuard>
</AdminLayout>
