---
import Layout from '../layouts/Layout.astro';
import { Button } from '@components/ui/Button';
import { WifiOff } from 'lucide-react';

export const prerender = true;
---

<Layout title="Sin Conexión" description="No tienes conexión a internet.">
  <div class="min-h-[70vh] flex flex-col items-center justify-center p-4 text-center">
    <div class="w-20 h-20 bg-muted rounded-full flex items-center justify-center mb-6">
      <WifiOff className="w-10 h-10 text-muted-foreground" />
    </div>
    
    <h1 class="text-3xl font-bold text-foreground mb-4">Estás sin conexión</h1>
    <p class="text-muted-foreground max-w-md mb-8 leading-relaxed">
      Parece que no tienes una conexión activa a internet. Algunas funciones de Culina Smart, como la generación de recetas con IA o la sincronización, no están disponibles actualmente.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <Button onClick={() => window.location.reload()}>
        Reintentar Conexión
      </Button>
      <a href="/" class="inline-flex items-center justify-center px-6 py-2 rounded-lg border border-border bg-card text-foreground hover:bg-muted transition-colors">
        Ir al Inicio
      </a>
    </div>

    <p class="mt-12 text-sm text-muted-foreground">
      Puedes seguir viendo las recetas que ya has cargado previamente.
    </p>
  </div>
</Layout>
