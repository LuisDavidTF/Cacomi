---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout 
	title={`${frontmatter.title} | Blog de Cacomi`}
	description={frontmatter.description}
	type="article"
>
	<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-20">
		<article class="bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-6 md:p-10">
			<header class="mb-8 border-b border-gray-100 dark:border-gray-800 pb-8">
				<div class="flex items-center gap-2 text-sm text-amber-600 dark:text-amber-500 font-medium mb-3">
					<span>{frontmatter.date}</span>
					<span>•</span>
					<span>{frontmatter.author}</span>
				</div>
				<h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
					{frontmatter.title}
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-400">
					{frontmatter.description}
				</p>
			</header>

			<div class="prose prose-lg dark:prose-invert max-w-none text-gray-700 dark:text-gray-300
						prose-headings:text-gray-900 dark:prose-headings:text-white prose-headings:font-semibold
						prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
						prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
						prose-p:leading-relaxed prose-p:mb-6
						prose-a:text-amber-600 dark:prose-a:text-amber-500 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
						prose-ul:list-disc prose-ul:pl-6 prose-ul:mb-6 prose-li:mb-2
						prose-strong:text-gray-900 dark:prose-strong:text-white prose-strong:font-bold">
				<slot />
			</div>
			
			<div class="mt-12 pt-8 border-t border-gray-100 dark:border-gray-800 text-center">
				<p class="text-gray-600 dark:text-gray-400 mb-4">¿Quieres empezar a aplicar estos consejos hoy mismo?</p>
				<a href="/" class="inline-block bg-amber-500 hover:bg-amber-600 text-white font-medium px-6 py-3 rounded-xl transition-colors">
					Ir a Cacomi
				</a>
			</div>
		</article>
	</div>
</Layout>
