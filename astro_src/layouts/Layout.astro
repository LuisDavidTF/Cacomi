---
import { ClientRouter } from 'astro:transitions';
import { Navbar } from '@components/ui/Navbar';
import { Footer } from '@components/ui/Footer';
import { AppProviders } from '@components/providers/AppProviders';
import { LegalsConsent } from '@components/ui/LegalsConsent';
import { pwaInfo } from 'virtual:pwa-info';
import '../layouts/globals.css';
import GoogleAnalytics from '@components/analytics/GoogleAnalytics.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
}

const { 
	title = 'Cacomi - Smart Recipe Planner', 
	description = 'Planifica tus comidas de forma inteligente con nuestra inteligencia artificial.',
	image = '/og-image.jpg',
	type = 'website'
} = Astro.props;

const adminPathPrefix = getEnv('ADMIN_PATH_PREFIX') || 'admin-dashboard';
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/png" href="/icon.png?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- PWA tags -->
		<meta name="theme-color" content="#ffffff" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Cacomi" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />
		
		{ pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />
		
		<GoogleAnalytics />

		<!-- Prevent FOUC & Theme Initialization -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>

		<!-- Legacy PWA Cleanup -->
		<script is:inline>
			(function() {
				const CURRENT_VERSION = 'cacomi-pwa-v5'; // Bumped for new Astro 6 structure
				const storedVersion = localStorage.getItem('pwa_version');
				
				if (storedVersion !== CURRENT_VERSION) {
					if ('serviceWorker' in navigator) {
						navigator.serviceWorker.getRegistrations().then(registrations => {
							for (const registration of registrations) {
								registration.unregister();
							}
						});
					}
					if ('caches' in window) {
						caches.keys().then(names => {
							for (const name of names) caches.delete(name);
						});
					}
					localStorage.setItem('pwa_version', CURRENT_VERSION);
				}
			})();
		</script>
		
		<ClientRouter />

		<!-- SW Registration & Warm Cache -->
		<script is:inline>
			// Register SW on production-like environments
			if ('serviceWorker' in navigator && window.location.hostname !== 'localhost' && !window.location.hostname.includes('127.0.0.1')) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js')
						.then(() => console.log('✅ PWA: Registered successfully'))
						.catch((err) => console.error('❌ PWA: Registration failed:', err));

					// Warm the cache with the recipe shell after load
					setTimeout(() => {
						fetch('/recipes/offline-shell').catch(() => {});
					}, 2000);
				});
			}
		</script>
	</head>
	<body class="min-h-screen font-sans antialiased bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-300" data-admin-path={`/${adminPathPrefix}`}>
		<AppProviders client:load>
			<div class="flex flex-col min-h-screen">
				<Navbar client:load />

				<main id="main-content" class="flex-grow pt-16">
					<slot />
				</main>

				<Footer client:load />
			</div>

			<LegalsConsent client:load />
		</AppProviders>

		{/* Static link for Google OAuth crawler - Outside React providers to avoid hydration errors */}
		<a href="/privacy" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0;" aria-hidden="true">Privacy Policy</a>
	</body>
</html>
