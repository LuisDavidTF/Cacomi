---
import { ClientRouter } from 'astro:transitions';
import { Navbar } from '@components/ui/Navbar';
import { Footer } from '@components/ui/Footer';
import { AppProviders } from '@components/providers/AppProviders';
import { LegalsConsent } from '@components/ui/LegalsConsent';
import { getEnv } from '@utils/env';
import '../layouts/globals.css';
import GoogleAnalytics from '@components/analytics/GoogleAnalytics.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = 'Cacomi - Smart Recipe Planner', 
	description = 'Planifica tus comidas de forma inteligente con nuestra inteligencia artificial.' 
} = Astro.props;

const adminPathPrefix = getEnv('ADMIN_PATH_PREFIX') || 'admin-dashboard';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- PWA tags -->
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#ffffff" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />
		
		<GoogleAnalytics />

		<!-- Prevent FOUC -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>
		
		<ClientRouter />

		<!-- Warm Cache for Offline Shell -->
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					// Warm the cache with the recipe shell after load
					// This ensures it's available offline without build-time precaching
					setTimeout(() => {
						fetch('/recipes/offline-shell').catch(() => {});
					}, 2000);
				});
			}
		</script>
	</head>
	<body class="min-h-screen font-sans antialiased bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-300" data-admin-path={`/${adminPathPrefix}`}>
		<AppProviders client:load>
			<div class="flex flex-col min-h-screen">
				<Navbar client:load />

				<main id="main-content" class="flex-grow pt-16">
					<slot />
				</main>

				<Footer client:load />
			</div>

			<LegalsConsent client:load />
		</AppProviders>

		{/* Static link for Google OAuth crawler - Outside React providers to avoid hydration errors */}
		<a href="/privacy" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0;" aria-hidden="true">Privacy Policy</a>
	</body>
</html>
