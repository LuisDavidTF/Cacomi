---
import { AppProviders } from '@components/providers/AppProviders';
import { Navbar } from '@components/ui/Navbar';
import { Footer } from '@components/ui/Footer';
import { LegalsConsent } from '@components/ui/LegalsConsent';
import { ViewTransitions } from 'astro:transitions';
import { ADMIN_PATH_PREFIX } from 'astro:env/server';
import { pwaInfo } from 'virtual:pwa-info';
import '../layouts/globals.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string | URL;
	type?: 'website' | 'article' | 'profile';
}

const { 
	title = 'Cacomi - Cocina Inteligente y Planificación de Comidas',
	description = 'Cacomi: El asistente de cocina con IA que gestiona tu despensa y planifica tus comidas de forma inteligente para ahorrar tiempo y dinero.',
	image = '/og-image.jpg', // Placeholder image URL for Open Graph
	canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url),
	type = 'website',
} = Astro.props;

const isStaging = Astro.url.hostname.endsWith('.pages.dev');

const enableAds = import.meta.env.PUBLIC_ENABLE_ADS === 'true';
// Secret admin path prefix — server-side only, never exposed to JS bundle via PUBLIC_
const adminPathPrefix = (ADMIN_PATH_PREFIX ?? import.meta.env.ADMIN_PATH_PREFIX ?? 'admin').replace(/^\/|\/$/g, '');

---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" />
		<link rel="icon" type="image/png" href="/icon.png?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		
		{isStaging && <meta name="robots" content="noindex, nofollow" />}
		
		<!-- PWA / Mobile Tags -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Cacomi" />
		<link rel="apple-touch-icon" href="/icon.png" />
		
		{ pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} /> }

		<script is:inline>
			// Manual Service Worker Registration with versioning and enhanced logging
			if ('serviceWorker' in navigator) {
				const swPath = '/sw.js?v=' + Date.now();
				console.log('Attempting to register Service Worker at:', swPath);
				
				navigator.serviceWorker.register(swPath, { scope: '/' })
					.then(reg => {
						console.log('✅ Service Worker registered successfully. Scope:', reg.scope);
						if (reg.waiting) {
							console.log('⏳ Service Worker waiting to activate...');
							reg.waiting.postMessage({ type: 'SKIP_WAITING' });
						}
					})
					.catch(err => {
						console.error('❌ Service Worker registration FAILED:', err);
						console.log('TIP: Make sure you are ONLINE for the first registration!');
					});
					
				navigator.serviceWorker.addEventListener('controllerchange', () => {
					console.log('🚀 New Service Worker is now in control!');
				});
			}
		</script>
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<meta name="theme-color" media="(prefers-color-scheme: light)" content="#f7f2ea" />
		<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#010006" />
		
		<!-- Google Fonts: Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<style>
			html {
				font-family: 'Inter', sans-serif;
			}
		</style>
		
		{enableAds && (
			<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2928206942835905" crossorigin="anonymous"></script>
		)}
		
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-X50BSFS1NL"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-X50BSFS1NL');
		</script>
		
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Cacomi",
			"applicationCategory": "LifestyleApplication",
			"operatingSystem": "All",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			}
		})} />
		
		<script is:inline>
			// Force cleanup of legacy Service Workers and caches from the old Next.js / Culina Smart version
			(function() {
				const CURRENT_VERSION = 'cacomi-pwa-v2';
				const storedVersion = localStorage.getItem('pwa_version');
				
				if (storedVersion !== CURRENT_VERSION) {
					console.log('Detected legacy PWA or new version. Clearing caches and workers...');
					
					// 1. Unregister all service workers
					if ('serviceWorker' in navigator) {
						navigator.serviceWorker.getRegistrations().then(registrations => {
							for (const registration of registrations) {
								registration.unregister().then(() => {
									console.log('Legacy Service Worker unregistered');
								});
							}
						});
					}
					
					// 2. Clear all cache storage
					if ('caches' in window) {
						caches.keys().then(names => {
							for (const name of names) {
								caches.delete(name).then(() => {
									console.log('Cache cleared:', name);
								});
							}
						});
					}
					
					localStorage.setItem('pwa_version', CURRENT_VERSION);
					
					// 3. Force reload after a short delay to allow cleanup to start
					// This ensures the new AstroPWA Service Worker can register cleanly
					setTimeout(() => {
						window.location.reload();
					}, 500);
				}
			})();
		</script>
		
		<ViewTransitions />
	</head>
	<body class="min-h-screen font-sans antialiased bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-300" data-admin-path={`/${adminPathPrefix}`}>
		<AppProviders client:load>
			<div class="flex flex-col min-h-screen">
				<Navbar client:load />

				<main id="main-content" class="flex-grow pt-16">
					<slot />
				</main>

				<Footer client:load />
			</div>

			<LegalsConsent client:load />
		</AppProviders>
	</body>
</html>
