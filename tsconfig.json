{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "strict": false,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "esModuleInterop": true,
    "incremental": true,
    "types": [
      "react",
      "react-dom",
      "astro/client",
      "vite-plugin-pwa/info",
      "vite-plugin-pwa/pwa-assets"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "astro_src/*"
      ],
      "@components/*": [
        "astro_src/components/*"
      ],
      "@context/*": [
        "astro_src/context/*"
      ],
      "@hooks/*": [
        "astro_src/hooks/*"
      ],
      "@utils/*": [
        "astro_src/utils/*"
      ],
      "@layouts/*": [
        "astro_src/layouts/*"
      ]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "astro_src/**/*.ts",
    "astro_src/**/*.tsx",
    "astro_src/**/*.mts",
    "astro_src/**/*.astro",
    "astro_src/env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}